DEV_MODE=true

# Database
DATABASE_URL=sqlite:///data/podcast.db

# Auth - Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth - GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session
SESSION_SECRET=change-me

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google Gemini
GEMINI_API_KEY=

# TTS provider: "glm", "google", or "inworld"
TTS_PROVIDER=inworld

# GLM (智谱) TTS
GLM_API_KEY=
TTS_VOICE_MALE=male
TTS_VOICE_FEMALE=female

# Google TTS (via Gemini) — uses GEMINI_API_KEY above
GOOGLE_TTS_MODEL=gemini-2.5-flash-preview-tts
GOOGLE_TTS_VOICE_MALE=Puck
GOOGLE_TTS_VOICE_FEMALE=Aoede

# Inworld TTS — https://inworld.ai (copy "Basic (Base64)" key from dashboard)
INWORLD_API_KEY=
INWORLD_TTS_MODEL=inworld-tts-1.5-max
INWORLD_TTS_VOICE_MALE=Theodore
INWORLD_TTS_VOICE_FEMALE=Sarah

# RSS Feeds (comma-separated, optional — defaults to 36kr/sspai/ifanr)
RSS_FEEDS=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
