# Environment: "development" or "production"
ENVIRONMENT=development

# Database backend: "d1" (Cloudflare D1) or "sqlite" (local file)
# Defaults to "sqlite" in development, "d1" in production
DATABASE_BACKEND=sqlite

DEV_MODE=false

# Cloudflare D1 — https://dash.cloudflare.com → Workers & Pages → D1
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=

# Auth - Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session
SESSION_SECRET=change-me

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google Gemini (used by Podcastfy, cover generation, and optionally LLM tasks)
GEMINI_API_KEY=

# ZhiPu AI — https://open.bigmodel.cn
ZHIPU_API_KEY=

# LLM provider per task: "zhipu" (default) or "gemini"
LLM_PROVIDER_FILTER=zhipu
LLM_PROVIDER_KEYWORDS=zhipu
LLM_PROVIDER_TITLE=zhipu

# LLM model names (override defaults per provider)
ZHIPU_MODEL=glm-5
GEMINI_MODEL=gemini-2.5-flash

# Google Vertex AI (for cover image generation, optional)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# TTS provider: "google" or "inworld"
TTS_PROVIDER=inworld

# Google TTS (via Gemini) — uses GEMINI_API_KEY above
GOOGLE_TTS_MODEL=gemini-2.5-flash-preview-tts
GOOGLE_TTS_VOICE_MALE=Puck
GOOGLE_TTS_VOICE_FEMALE=Aoede

# Inworld TTS — https://inworld.ai (copy "Basic (Base64)" key from dashboard)
INWORLD_API_KEY=
INWORLD_TTS_MODEL=inworld-tts-1.5-max
INWORLD_TTS_VOICE_MALE=Theodore
INWORLD_TTS_VOICE_FEMALE=Kayla

# RSS Feeds (comma-separated, optional — defaults to 36kr/sspai/ifanr)
RSS_FEEDS=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
